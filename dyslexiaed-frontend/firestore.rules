rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isGuardian() {
      return isAuthenticated() && getUserRole() == 'guardian';
    }

    function isTeacher() {
      return isAuthenticated() && getUserRole() == 'teacher';
    }

    function isStudent() {
      return isAuthenticated() && getUserRole() == 'student';
    }

    function isLinkedGuardian(studentId) {
      return isGuardian() &&
        studentId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.linkedStudentIds;
    }

    function isAssignedTeacher(studentId) {
      return isTeacher() &&
        request.auth.uid == get(/databases/$(database)/documents/students/$(studentId)).data.teacherId;
    }

    // Users collection
    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if false; // Only via Admin SDK
    }

    // Students collection
    match /students/{studentId} {
      allow read: if isAuthenticated() && (
        resource.data.uid == request.auth.uid ||
        isLinkedGuardian(studentId) ||
        isAssignedTeacher(studentId)
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.uid == request.auth.uid ||
        isAssignedTeacher(studentId)
      );
      allow delete: if false;
    }

    // Sessions collection
    match /sessions/{sessionId} {
      allow read: if isAuthenticated() && (
        resource.data.studentId == request.auth.uid ||
        isLinkedGuardian(resource.data.studentId) ||
        isAssignedTeacher(resource.data.studentId)
      );
      allow create: if isAuthenticated() && request.resource.data.studentId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.studentId == request.auth.uid;
      allow delete: if false;
    }

    // Handwriting samples
    match /handwritingSamples/{sampleId} {
      allow read: if isAuthenticated() && (
        resource.data.studentId == request.auth.uid ||
        isLinkedGuardian(resource.data.studentId) ||
        isAssignedTeacher(resource.data.studentId)
      );
      allow create: if isAuthenticated() && request.resource.data.studentId == request.auth.uid;
      allow update: if false; // Only via Admin SDK (ML service)
      allow delete: if false;
    }

    // Analysis results — read-only for clients, written by Admin SDK
    match /analysisResults/{resultId} {
      allow read: if isAuthenticated() && (
        resource.data.studentId == request.auth.uid ||
        isLinkedGuardian(resource.data.studentId) ||
        isAssignedTeacher(resource.data.studentId)
      );
      allow write: if false; // Only via Admin SDK
    }

    // Behaviour snapshots
    match /behaviourSnapshots/{snapshotId} {
      allow read: if isAuthenticated() && (
        resource.data.studentId == request.auth.uid ||
        isLinkedGuardian(resource.data.studentId) ||
        isAssignedTeacher(resource.data.studentId)
      );
      allow write: if false; // Only via Admin SDK / Cloud Functions
    }

    // Reports
    match /reports/{reportId} {
      allow read: if isAuthenticated() && (
        resource.data.guardianId == request.auth.uid ||
        isAssignedTeacher(resource.data.studentId)
      );
      allow write: if false; // Only via Admin SDK
    }

    // Assignments (teacher-created)
    match /assignments/{assignmentId} {
      allow read: if isAuthenticated();
      allow create: if isTeacher();
      allow update: if isTeacher();
      allow delete: if isTeacher();
    }

    // Audit log — append only
    match /auditLog/{logId} {
      allow read: if false; // Admin only
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if false;
    }
  }
}
